api:
  dashboard: {{ traefik_settings.dashboard | lower }}

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"

providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    watch: true

certificatesResolvers:
  letsencrypt:
    acme:
      email: "{{ traefik_settings.letsencrypt.email }}"
      storage: /data/acme.json
      httpChallenge:
        entryPoint: web

log:
  level: DEBUG
